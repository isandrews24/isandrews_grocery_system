SECRET_KEY=change-me-generate-with-secrets-token-hex
DATABASE_URL=sqlite:///instance/grocery.db
FLASK_ENV=development
STORE_NAME=isAndrews Grocery
STORE_TIN=
VAT_RATE=15.0
NHIL_RATE=2.5
GETFUND_RATE=2.5

# Mobile money / card gateways - leave blank to run in stub/demo mode
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_ENVIRONMENT=sandbox
VODAFONE_API_KEY=
VODAFONE_API_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Email receipts - leave MAIL_USERNAME blank to run in suppressed/demo mode (no send attempted)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=

# Thermal receipt printer - leave PRINTER_TYPE blank to run in demo mode (captures output, prints nothing)
PRINTER_TYPE=
PRINTER_USB_VENDOR_ID=
PRINTER_USB_PRODUCT_ID=
PRINTER_NETWORK_IP=

# SMS receipts (Hubtel) - leave blank to run in demo mode (no send attempted)
HUBTEL_SMS_CLIENT_ID=
HUBTEL_SMS_CLIENT_SECRET=
HUBTEL_SMS_SENDER_ID=isAndrewsGro

# GRA Electronic Fiscal Device transmission - leave GRA_EFD_ENDPOINT blank to run in
# demo mode (transactions formatted but not transmitted). Only VAT-registered retailers
# above the GHS 200,000 turnover threshold need this - see Appendix C.2 of the manual.
GRA_EFD_ENDPOINT=
GRA_EFD_API_KEY=
GRA_EFD_DEVICE_NUMBER=
